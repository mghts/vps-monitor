# PostgreSQL 配置。POSTGRES_PASSWORD 必须改成随机长密码。
POSTGRES_DB=vps_monitor
POSTGRES_USER=vps_monitor
POSTGRES_PASSWORD=change-this-long-random-password

# 首次注册管理员和忘记密码重置用的令牌，不是网页登录密码。
# 至少 32 个字符，建议用 openssl rand -hex 32 生成。
SETUP_TOKEN=change-this-one-time-setup-token

# 对外访问地址。生产环境必须写你的 HTTPS 域名。
BASE_URL=https://monitor.example.com

# 推荐只监听本机，由 Nginx 反向代理到公网 80/443。
SERVER_PORT=127.0.0.1:8080

# 中心端和 Docker Agent 镜像。生产环境建议固定版本号，不要长期使用 latest。
SERVER_IMAGE=your-dockerhub-user/vps-monitor-server:v0.2.2
AGENT_IMAGE=your-dockerhub-user/vps-monitor-agent:v0.2.2

# Agent 一键安装脚本。生产环境建议固定到已审核的 release tag 或完整 commit SHA；
# refs/heads/main 便于开发，但它是可变地址。
AGENT_INSTALLER_URL=https://raw.githubusercontent.com/mghts/vps-monitor/refs/heads/main/agent/install.sh

# systemd/native Agent 二进制从这个仓库的 GitHub Releases 下载。
# 如果已经在 agent/install.sh 里固定 DEFAULT_RELEASE_REPO，这里可以留空，安装命令会更短。
AGENT_RELEASE_REPOSITORY=

# 留空或 latest 表示使用 latest release；也可以固定为 v0.2.2 这样的 tag。
AGENT_RELEASE_TAG=latest

# GeoIP 更新按钮会把 MaxMind 兼容 MMDB 下载到这里；Docker 部署保持默认即可。
GEOIP_MMDB_PATH=/data/GeoLite2-City.mmdb

# 默认 MMDB 下载 URL 在后台设置里，可按需改成自己的 .mmdb 或 .mmdb.gz 来源。
# 自定义背景会保存到该目录；Docker 部署保持默认即可。
BACKGROUND_DIR=/data/backgrounds

# HTTPS 生产部署保持 true。只有纯 HTTP 临时测试登录时才改成 false。
COOKIE_SECURE=true

# 使用本项目的 Nginx 反代且 SERVER_PORT 仅绑定 127.0.0.1 时保持 true。
# 如果中心端直接暴露到公网，必须改成 false，否则客户端可伪造来源 IP 请求头。
TRUST_PROXY_HEADERS=true

RUST_LOG=info
